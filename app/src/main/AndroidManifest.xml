<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!--
      Used only on the "Import from Contacts" screen, to show the owner their
      contact list so they can pick who to add as a customer. Requested at the
      moment they open that screen, never at launch. Contacts are not uploaded
      or stored; only the ones deliberately chosen are saved. The app works
      fully without this permission — parties can always be added by hand.
    -->
    <uses-permission android:name="android.permission.READ_CONTACTS" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.RoshanKhata">

        <!--
          The gate. It decides whether the ledger needs unlocking and hands
          straight through when App Lock is off, so an unlocked app costs the
          user nothing.
        -->
        <!-- Splash is the launcher now; Gate is reached from it. -->
        <activity
            android:name=".SplashActivity"
            android:exported="true"
            android:noHistory="true"
            android:theme="@style/Theme.RoshanKhata.Splash">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".GateActivity"
            android:exported="false"
            android:noHistory="true"
            android:theme="@style/Theme.RoshanKhata" />

        <activity
            android:name=".LockActivity"
            android:exported="false"
            android:noHistory="true" />

        <activity
            android:name=".MainActivity"
            android:exported="false" />

        <activity
            android:name=".PartyDetailActivity"
            android:exported="false"
            android:parentActivityName=".MainActivity" />

        <activity
            android:name=".RecycleBinActivity"
            android:exported="false"
            android:parentActivityName=".MainActivity" />

        <activity
            android:name=".ZakatActivity"
            android:exported="false"
            android:parentActivityName=".MainActivity" />

        <activity
            android:name=".ImportContactsActivity"
            android:exported="false"
            android:parentActivityName=".MainActivity" />

        <activity
            android:name=".BusinessSettingsActivity"
            android:exported="false"
            android:parentActivityName=".MainActivity" />

        <activity
            android:name=".ChequesActivity"
            android:exported="false"
            android:parentActivityName=".MainActivity" />

        <activity
            android:name=".ReportActivity"
            android:exported="false"
            android:parentActivityName=".MainActivity" />

        <activity
            android:name=".CashbookActivity"
            android:exported="false"
            android:parentActivityName=".MainActivity" />

        <activity
            android:name=".BackupActivity"
            android:exported="false"
            android:parentActivityName=".MainActivity" />

        <activity
            android:name=".ReportProblemActivity"
            android:exported="false"
            android:parentActivityName=".MainActivity" />

        <activity
            android:name=".PlansActivity"
            android:exported="false"
            android:parentActivityName=".MainActivity" />

        <activity
            android:name=".BillsActivity"
            android:exported="false"
            android:parentActivityName=".MainActivity" />

        <activity
            android:name=".ExpiringActivity"
            android:exported="false"
            android:parentActivityName=".BillsActivity" />

        <!--
          Lets a statement PDF be handed to WhatsApp, Gmail, or the printer
          without exposing the rest of the app's storage. Grants are temporary
          and per-share.
        -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

    </application>

</manifest>
