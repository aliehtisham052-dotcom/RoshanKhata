<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Cloud backup to the user's own Google Drive -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!--
      Used only on the "Import from Contacts" screen, to show the owner their
      contact list so they can pick who to add as a customer. Requested at the
      moment they open that screen, never at launch. Contacts are not uploaded
      or stored; only the ones deliberately chosen are saved. The app works
      fully without this permission — parties can always be added by hand.
    -->
    <uses-permission android:name="android.permission.READ_CONTACTS" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.RoshanKhata">

        <!--
          The gate. It decides whether the ledger needs unlocking and hands
          straight through when App Lock is off, so an unlocked app costs the
          user nothing.
        -->
        <!--
          The launcher is now GateActivity directly. The old SplashActivity
          showed the logo a second time after the system splash already had —
          two logo beats that read as the app opening twice. Removed it: the OS
          shows our mark once during cold start (the Splash theme below), then
          Gate decides lock-or-home. One logo, then straight in.
        -->
        <activity
            android:name=".LanguageActivity"
            android:exported="false"
            android:theme="@style/Theme.RoshanKhata" />

        <activity
            android:name=".GateActivity"
            android:exported="true"
            android:noHistory="true"
            android:theme="@style/Theme.RoshanKhata">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".LockActivity"
            android:exported="false"
            android:noHistory="true"
            android:windowSoftInputMode="adjustNothing" />

        <activity
            android:name=".MainActivity"
            android:exported="false" />

        <activity
            android:name=".KhataActivity"
            android:exported="false"
            android:parentActivityName=".MainActivity" />

        <activity
            android:name=".PartyDetailActivity"
            android:exported="false"
            android:parentActivityName=".KhataActivity" />

        <activity
            android:name=".EntryDetailActivity"
            android:exported="false"
            android:theme="@style/Theme.RoshanKhata" />

        <activity
            android:name=".CalculatorActivity"
            android:exported="false"
            android:parentActivityName=".MainActivity" />

        <activity
            android:name=".RecycleBinActivity"
            android:exported="false"
            android:parentActivityName=".MainActivity" />

        <activity
            android:name=".ZakatActivity"
            android:exported="false"
            android:parentActivityName=".MainActivity" />

        <activity
            android:name=".ImportContactsActivity"
            android:exported="false"
            android:parentActivityName=".MainActivity" />

        <activity
            android:name=".BusinessSettingsActivity"
            android:exported="false"
            android:parentActivityName=".MainActivity" />

        <activity
            android:name=".BusinessCardActivity"
            android:exported="false"
            android:parentActivityName=".MainActivity" />

        <activity
            android:name=".ChequesActivity"
            android:exported="false"
            android:parentActivityName=".MainActivity" />

        <activity
            android:name=".ReportActivity"
            android:exported="false"
            android:parentActivityName=".MainActivity" />

        <activity
            android:name=".CashbookActivity"
            android:exported="false"
            android:parentActivityName=".MainActivity" />

        <activity
            android:name=".BackupActivity"
            android:exported="false"
            android:parentActivityName=".MainActivity" />

        <activity
            android:name=".ReportProblemActivity"
            android:exported="false"
            android:parentActivityName=".MainActivity" />

        <activity
            android:name=".PlansActivity"
            android:exported="false"
            android:parentActivityName=".MainActivity" />

        <activity
            android:name=".BillsActivity"
            android:exported="false"
            android:parentActivityName=".MainActivity" />

        <activity
            android:name=".ExpiringActivity"
            android:exported="false"
            android:parentActivityName=".BillsActivity" />

        <!--
          Lets a statement PDF be handed to WhatsApp, Gmail, or the printer
          without exposing the rest of the app's storage. Grants are temporary
          and per-share.
        -->
        <!--
          AndroidX persists the user's chosen app language automatically through
          this disabled holder service (autoStoreLocales). On Android 13+ the
          system takes over; below that AppCompat replays the choice on start.
        -->
        <service
            android:name="androidx.appcompat.app.AppLocalesMetadataHolderService"
            android:enabled="false"
            android:exported="false">
            <meta-data
                android:name="autoStoreLocales"
                android:value="true" />
        </service>

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

            <activity
            android:name=".InsightsActivity"
            android:exported="false" />

    </application>

</manifest>
