<?xml version="1.0" encoding="utf-8"?>
<!--
  Full number pad for amount entry. Colors are set directly on each button
  (backgroundTint + textColor) rather than via a style, because the Material
  Button was overriding a style-set background and rendering black. Explicit
  tints are the reliable path: white number keys with dark text, muted keys for
  C/÷/×/⌫, tinted operators, brand-green =.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="6dp">

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
        <Button android:id="@+id/calcClear" android:layout_width="0dp" android:layout_height="54dp" android:layout_weight="1" android:layout_margin="3dp" android:text="C" android:textColor="#1B5E3A" android:textSize="18sp" android:backgroundTint="#E4ECE8" />
        <Button android:id="@+id/calcDivide" android:layout_width="0dp" android:layout_height="54dp" android:layout_weight="1" android:layout_margin="3dp" android:text="÷" android:textColor="#1B5E3A" android:textSize="18sp" android:backgroundTint="#E4ECE8" />
        <Button android:id="@+id/calcTimes" android:layout_width="0dp" android:layout_height="54dp" android:layout_weight="1" android:layout_margin="3dp" android:text="×" android:textColor="#1B5E3A" android:textSize="18sp" android:backgroundTint="#E4ECE8" />
        <Button android:id="@+id/calcBack" android:layout_width="0dp" android:layout_height="54dp" android:layout_weight="1" android:layout_margin="3dp" android:text="⌫" android:textColor="#A32D2D" android:textSize="18sp" android:backgroundTint="#E4ECE8" />
    </LinearLayout>

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
        <Button android:id="@+id/calc7" android:layout_width="0dp" android:layout_height="54dp" android:layout_weight="1" android:layout_margin="3dp" android:text="7" android:textColor="#1A1A18" android:textSize="20sp" android:backgroundTint="#EEF1EF" />
        <Button android:id="@+id/calc8" android:layout_width="0dp" android:layout_height="54dp" android:layout_weight="1" android:layout_margin="3dp" android:text="8" android:textColor="#1A1A18" android:textSize="20sp" android:backgroundTint="#EEF1EF" />
        <Button android:id="@+id/calc9" android:layout_width="0dp" android:layout_height="54dp" android:layout_weight="1" android:layout_margin="3dp" android:text="9" android:textColor="#1A1A18" android:textSize="20sp" android:backgroundTint="#EEF1EF" />
        <Button android:id="@+id/calcMinus" android:layout_width="0dp" android:layout_height="54dp" android:layout_weight="1" android:layout_margin="3dp" android:text="−" android:textColor="#FFFFFF" android:textSize="20sp" android:backgroundTint="#7FA99B" />
    </LinearLayout>

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
        <Button android:id="@+id/calc4" android:layout_width="0dp" android:layout_height="54dp" android:layout_weight="1" android:layout_margin="3dp" android:text="4" android:textColor="#1A1A18" android:textSize="20sp" android:backgroundTint="#EEF1EF" />
        <Button android:id="@+id/calc5" android:layout_width="0dp" android:layout_height="54dp" android:layout_weight="1" android:layout_margin="3dp" android:text="5" android:textColor="#1A1A18" android:textSize="20sp" android:backgroundTint="#EEF1EF" />
        <Button android:id="@+id/calc6" android:layout_width="0dp" android:layout_height="54dp" android:layout_weight="1" android:layout_margin="3dp" android:text="6" android:textColor="#1A1A18" android:textSize="20sp" android:backgroundTint="#EEF1EF" />
        <Button android:id="@+id/calcPlus" android:layout_width="0dp" android:layout_height="54dp" android:layout_weight="1" android:layout_margin="3dp" android:text="+" android:textColor="#FFFFFF" android:textSize="20sp" android:backgroundTint="#7FA99B" />
    </LinearLayout>

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
        <Button android:id="@+id/calc1" android:layout_width="0dp" android:layout_height="54dp" android:layout_weight="1" android:layout_margin="3dp" android:text="1" android:textColor="#1A1A18" android:textSize="20sp" android:backgroundTint="#EEF1EF" />
        <Button android:id="@+id/calc2" android:layout_width="0dp" android:layout_height="54dp" android:layout_weight="1" android:layout_margin="3dp" android:text="2" android:textColor="#1A1A18" android:textSize="20sp" android:backgroundTint="#EEF1EF" />
        <Button android:id="@+id/calc3" android:layout_width="0dp" android:layout_height="54dp" android:layout_weight="1" android:layout_margin="3dp" android:text="3" android:textColor="#1A1A18" android:textSize="20sp" android:backgroundTint="#EEF1EF" />
        <Button android:id="@+id/calcDot" android:layout_width="0dp" android:layout_height="54dp" android:layout_weight="1" android:layout_margin="3dp" android:text="." android:textColor="#1A1A18" android:textSize="20sp" android:backgroundTint="#EEF1EF" />
    </LinearLayout>

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
        <Button android:id="@+id/calc0" android:layout_width="0dp" android:layout_height="54dp" android:layout_weight="1" android:layout_margin="3dp" android:text="0" android:textColor="#1A1A18" android:textSize="20sp" android:backgroundTint="#EEF1EF" />
        <Button android:id="@+id/calc00" android:layout_width="0dp" android:layout_height="54dp" android:layout_weight="1" android:layout_margin="3dp" android:text="00" android:textColor="#1A1A18" android:textSize="20sp" android:backgroundTint="#EEF1EF" />
        <Button android:id="@+id/calcEquals" android:layout_width="0dp" android:layout_height="54dp" android:layout_weight="2" android:layout_margin="3dp" android:text="=" android:textColor="#FFFFFF" android:textSize="20sp" android:backgroundTint="#1B5E3A" />
    </LinearLayout>

</LinearLayout>
