<?xml version="1.0" encoding="utf-8"?>
<!--
  Even grid with = filling the bottom-right corner. Left three columns hold the
  digits and dot in equal keys; the right column holds ⌫, −, +, then a taller =
  that fills the last two slots so there's no empty gap. Every key is the same
  width; only = is taller, by request. Plain LinearLayouts, no GridLayout.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="8dp">

    <!-- LEFT: three columns (C÷×, 789, 456, 123, 0-00-dot) -->
    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="3" android:orientation="vertical">

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
            <Button android:id="@+id/calcClear" android:layout_width="0dp" android:layout_height="62dp" android:layout_weight="1" android:layout_margin="3dp" android:padding="0dp" android:minWidth="0dp" android:minHeight="0dp" android:text="C" android:textColor="#1B5E3A" android:textSize="19sp" android:maxLines="1" android:textAllCaps="false" android:includeFontPadding="false" android:backgroundTint="#DCE7E0" android:insetTop="0dp" android:insetBottom="0dp" android:insetLeft="0dp" android:insetRight="0dp" />
            <Button android:id="@+id/calcDivide" android:layout_width="0dp" android:layout_height="62dp" android:layout_weight="1" android:layout_margin="3dp" android:padding="0dp" android:minWidth="0dp" android:minHeight="0dp" android:text="÷" android:textColor="#1B5E3A" android:textSize="19sp" android:maxLines="1" android:textAllCaps="false" android:includeFontPadding="false" android:backgroundTint="#DCE7E0" android:insetTop="0dp" android:insetBottom="0dp" android:insetLeft="0dp" android:insetRight="0dp" />
            <Button android:id="@+id/calcTimes" android:layout_width="0dp" android:layout_height="62dp" android:layout_weight="1" android:layout_margin="3dp" android:padding="0dp" android:minWidth="0dp" android:minHeight="0dp" android:text="×" android:textColor="#1B5E3A" android:textSize="19sp" android:maxLines="1" android:textAllCaps="false" android:includeFontPadding="false" android:backgroundTint="#DCE7E0" android:insetTop="0dp" android:insetBottom="0dp" android:insetLeft="0dp" android:insetRight="0dp" />
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
            <Button android:id="@+id/calc7" android:layout_width="0dp" android:layout_height="62dp" android:layout_weight="1" android:layout_margin="3dp" android:padding="0dp" android:minWidth="0dp" android:minHeight="0dp" android:text="7" android:textColor="#1A1A18" android:textSize="21sp" android:maxLines="1" android:textAllCaps="false" android:includeFontPadding="false" android:backgroundTint="#EFF1EF" android:insetTop="0dp" android:insetBottom="0dp" android:insetLeft="0dp" android:insetRight="0dp" />
            <Button android:id="@+id/calc8" android:layout_width="0dp" android:layout_height="62dp" android:layout_weight="1" android:layout_margin="3dp" android:padding="0dp" android:minWidth="0dp" android:minHeight="0dp" android:text="8" android:textColor="#1A1A18" android:textSize="21sp" android:maxLines="1" android:textAllCaps="false" android:includeFontPadding="false" android:backgroundTint="#EFF1EF" android:insetTop="0dp" android:insetBottom="0dp" android:insetLeft="0dp" android:insetRight="0dp" />
            <Button android:id="@+id/calc9" android:layout_width="0dp" android:layout_height="62dp" android:layout_weight="1" android:layout_margin="3dp" android:padding="0dp" android:minWidth="0dp" android:minHeight="0dp" android:text="9" android:textColor="#1A1A18" android:textSize="21sp" android:maxLines="1" android:textAllCaps="false" android:includeFontPadding="false" android:backgroundTint="#EFF1EF" android:insetTop="0dp" android:insetBottom="0dp" android:insetLeft="0dp" android:insetRight="0dp" />
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
            <Button android:id="@+id/calc4" android:layout_width="0dp" android:layout_height="62dp" android:layout_weight="1" android:layout_margin="3dp" android:padding="0dp" android:minWidth="0dp" android:minHeight="0dp" android:text="4" android:textColor="#1A1A18" android:textSize="21sp" android:maxLines="1" android:textAllCaps="false" android:includeFontPadding="false" android:backgroundTint="#EFF1EF" android:insetTop="0dp" android:insetBottom="0dp" android:insetLeft="0dp" android:insetRight="0dp" />
            <Button android:id="@+id/calc5" android:layout_width="0dp" android:layout_height="62dp" android:layout_weight="1" android:layout_margin="3dp" android:padding="0dp" android:minWidth="0dp" android:minHeight="0dp" android:text="5" android:textColor="#1A1A18" android:textSize="21sp" android:maxLines="1" android:textAllCaps="false" android:includeFontPadding="false" android:backgroundTint="#EFF1EF" android:insetTop="0dp" android:insetBottom="0dp" android:insetLeft="0dp" android:insetRight="0dp" />
            <Button android:id="@+id/calc6" android:layout_width="0dp" android:layout_height="62dp" android:layout_weight="1" android:layout_margin="3dp" android:padding="0dp" android:minWidth="0dp" android:minHeight="0dp" android:text="6" android:textColor="#1A1A18" android:textSize="21sp" android:maxLines="1" android:textAllCaps="false" android:includeFontPadding="false" android:backgroundTint="#EFF1EF" android:insetTop="0dp" android:insetBottom="0dp" android:insetLeft="0dp" android:insetRight="0dp" />
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
            <Button android:id="@+id/calc1" android:layout_width="0dp" android:layout_height="62dp" android:layout_weight="1" android:layout_margin="3dp" android:padding="0dp" android:minWidth="0dp" android:minHeight="0dp" android:text="1" android:textColor="#1A1A18" android:textSize="21sp" android:maxLines="1" android:textAllCaps="false" android:includeFontPadding="false" android:backgroundTint="#EFF1EF" android:insetTop="0dp" android:insetBottom="0dp" android:insetLeft="0dp" android:insetRight="0dp" />
            <Button android:id="@+id/calc2" android:layout_width="0dp" android:layout_height="62dp" android:layout_weight="1" android:layout_margin="3dp" android:padding="0dp" android:minWidth="0dp" android:minHeight="0dp" android:text="2" android:textColor="#1A1A18" android:textSize="21sp" android:maxLines="1" android:textAllCaps="false" android:includeFontPadding="false" android:backgroundTint="#EFF1EF" android:insetTop="0dp" android:insetBottom="0dp" android:insetLeft="0dp" android:insetRight="0dp" />
            <Button android:id="@+id/calc3" android:layout_width="0dp" android:layout_height="62dp" android:layout_weight="1" android:layout_margin="3dp" android:padding="0dp" android:minWidth="0dp" android:minHeight="0dp" android:text="3" android:textColor="#1A1A18" android:textSize="21sp" android:maxLines="1" android:textAllCaps="false" android:includeFontPadding="false" android:backgroundTint="#EFF1EF" android:insetTop="0dp" android:insetBottom="0dp" android:insetLeft="0dp" android:insetRight="0dp" />
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
            <Button android:id="@+id/calc0" android:layout_width="0dp" android:layout_height="62dp" android:layout_weight="1" android:layout_margin="3dp" android:padding="0dp" android:minWidth="0dp" android:minHeight="0dp" android:text="0" android:textColor="#1A1A18" android:textSize="21sp" android:maxLines="1" android:textAllCaps="false" android:includeFontPadding="false" android:backgroundTint="#EFF1EF" android:insetTop="0dp" android:insetBottom="0dp" android:insetLeft="0dp" android:insetRight="0dp" />
            <Button android:id="@+id/calc00" android:layout_width="0dp" android:layout_height="62dp" android:layout_weight="1" android:layout_margin="3dp" android:padding="0dp" android:minWidth="0dp" android:minHeight="0dp" android:text="00" android:textColor="#1A1A18" android:textSize="21sp" android:maxLines="1" android:textAllCaps="false" android:includeFontPadding="false" android:backgroundTint="#EFF1EF" android:insetTop="0dp" android:insetBottom="0dp" android:insetLeft="0dp" android:insetRight="0dp" />
            <Button android:id="@+id/calcDot" android:layout_width="0dp" android:layout_height="62dp" android:layout_weight="1" android:layout_margin="3dp" android:padding="0dp" android:minWidth="0dp" android:minHeight="0dp" android:text="." android:textColor="#1A1A18" android:textSize="21sp" android:maxLines="1" android:textAllCaps="false" android:includeFontPadding="false" android:backgroundTint="#EFF1EF" android:insetTop="0dp" android:insetBottom="0dp" android:insetLeft="0dp" android:insetRight="0dp" />
        </LinearLayout>

    </LinearLayout>

    <!-- RIGHT: ⌫, −, +, then tall = filling the last two slots -->
    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
        <Button android:id="@+id/calcBack" android:layout_width="match_parent" android:layout_height="62dp" android:layout_margin="3dp" android:padding="0dp" android:minWidth="0dp" android:minHeight="0dp" android:text="⌫" android:textColor="#A32D2D" android:textSize="19sp" android:maxLines="1" android:textAllCaps="false" android:includeFontPadding="false" android:backgroundTint="#DCE7E0" android:insetTop="0dp" android:insetBottom="0dp" android:insetLeft="0dp" android:insetRight="0dp" />
        <Button android:id="@+id/calcMinus" android:layout_width="match_parent" android:layout_height="62dp" android:layout_margin="3dp" android:padding="0dp" android:minWidth="0dp" android:minHeight="0dp" android:text="−" android:textColor="#FFFFFF" android:textSize="21sp" android:maxLines="1" android:textAllCaps="false" android:includeFontPadding="false" android:backgroundTint="#7FA99B" android:insetTop="0dp" android:insetBottom="0dp" android:insetLeft="0dp" android:insetRight="0dp" />
        <Button android:id="@+id/calcPlus" android:layout_width="match_parent" android:layout_height="62dp" android:layout_margin="3dp" android:padding="0dp" android:minWidth="0dp" android:minHeight="0dp" android:text="+" android:textColor="#FFFFFF" android:textSize="21sp" android:maxLines="1" android:textAllCaps="false" android:includeFontPadding="false" android:backgroundTint="#7FA99B" android:insetTop="0dp" android:insetBottom="0dp" android:insetLeft="0dp" android:insetRight="0dp" />
        <Button android:id="@+id/calcEquals" android:layout_width="match_parent" android:layout_height="130dp" android:layout_margin="3dp" android:padding="0dp" android:minWidth="0dp" android:minHeight="0dp" android:text="=" android:textColor="#FFFFFF" android:textSize="22sp" android:maxLines="1" android:textAllCaps="false" android:includeFontPadding="false" android:backgroundTint="#1B5E3A" android:insetTop="0dp" android:insetBottom="0dp" android:insetLeft="0dp" android:insetRight="0dp" />
    </LinearLayout>

</LinearLayout>
