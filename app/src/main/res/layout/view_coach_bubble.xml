<?xml version="1.0" encoding="utf-8"?>
<!--
  The explanation bubble for one coach mark step. Positioned in code above or
  below the spotlight hole, whichever side has room. Kept short on purpose —
  this sits in a small card over the real screen, not a full slide.
-->
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="280dp"
    android:layout_height="wrap_content"
    app:cardBackgroundColor="@color/white"
    app:cardCornerRadius="14dp"
    app:cardElevation="10dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="18dp">

        <TextView
            android:id="@+id/tvCoachStep"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/text_muted"
            android:textSize="11sp"
            android:textStyle="bold"
            tools:text="1 of 8" />

        <TextView
            android:id="@+id/tvCoachTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="@color/ink"
            android:textSize="16sp"
            android:textStyle="bold"
            tools:text="Your Balance" />

        <TextView
            android:id="@+id/tvCoachDesc"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:lineSpacingExtra="2dp"
            android:textColor="@color/ink_soft"
            android:textSize="13sp"
            tools:text="See what you're owed and what you owe, at a glance." />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvCoachSkip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="?attr/selectableItemBackground"
                android:padding="8dp"
                android:text="@string/coach_skip"
                android:textColor="@color/text_muted"
                android:textSize="13sp" />

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <Button
                android:id="@+id/btnCoachNext"
                style="@style/Widget.MaterialComponents.Button"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minWidth="0dp"
                android:paddingStart="20dp"
                android:paddingTop="8dp"
                android:paddingEnd="20dp"
                android:paddingBottom="8dp"
                android:text="@string/coach_next"
                android:textSize="13sp"
                app:backgroundTint="@color/brand_green"
                app:cornerRadius="8dp" />

        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>
