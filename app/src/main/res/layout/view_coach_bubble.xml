<?xml version="1.0" encoding="utf-8"?>
<!--
  The walkthrough card for one coach mark step. Sits centred over the dimmed
  screen while the spotlight picks out the control being described, so it
  never lands on top of the thing it is pointing at — the competitor's
  arrangement, and the one that survives a small screen.

  Skip sits opposite the dots, well away from the full-width NEXT, so the
  owner cannot end the tour by aiming badly.
-->
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardBackgroundColor="@color/white"
    app:cardCornerRadius="20dp"
    app:cardElevation="12dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="22dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="@string/coach_walkthrough"
            android:textColor="@color/ink"
            android:textSize="21sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:gravity="center"
            android:text="@string/coach_home_screen"
            android:textColor="@color/ink_soft"
            android:textSize="15sp" />

        <!-- Progress dots on the left, Skip well clear of them on the right. -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <LinearLayout
                android:id="@+id/coachDots"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal" />

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <TextView
                android:id="@+id/tvCoachSkip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="?attr/selectableItemBackground"
                android:paddingStart="12dp"
                android:paddingTop="6dp"
                android:paddingEnd="4dp"
                android:paddingBottom="6dp"
                android:text="@string/coach_skip"
                android:textColor="@color/ink_soft"
                android:textSize="15sp"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvCoachTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:textColor="@color/ink"
            android:textSize="19sp"
            android:textStyle="bold"
            tools:text="Your Balance" />

        <TextView
            android:id="@+id/tvCoachDesc"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:lineSpacingExtra="5dp"
            android:textColor="@color/ink_soft"
            android:textSize="15sp"
            tools:text="See what you're owed and what you owe, at a glance." />

        <!--
          Full width and tall enough for a thumb. The tour is the only thing on
          screen at this moment, so the primary action gets the whole row.
        -->
        <Button
            android:id="@+id/btnCoachNext"
            style="@style/Widget.MaterialComponents.Button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:minHeight="54dp"
            android:text="@string/coach_next"
            android:textAllCaps="true"
            android:textSize="16sp"
            android:textStyle="bold"
            app:backgroundTint="@color/brand_green"
            app:cornerRadius="27dp" />

    </LinearLayout>
</androidx.cardview.widget.CardView>
