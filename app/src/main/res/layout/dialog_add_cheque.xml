<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingTop="8dp"
        android:paddingEnd="24dp"
        android:paddingBottom="8dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/cheque_not_money_yet"
            android:textColor="@color/text_muted"
            android:textSize="12sp" />

        <AutoCompleteTextView
            android:id="@+id/etChequeParty"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:completionThreshold="1"
            android:hint="@string/cheque_party_hint"
            android:importantForAutofill="no"
            android:inputType="text" />

        <RadioGroup
            android:id="@+id/rgChequeDirection"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal">

            <RadioButton
                android:id="@+id/rbReceived"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="true"
                android:text="@string/cheque_received"
                android:textSize="13sp" />

            <RadioButton
                android:id="@+id/rbIssued"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:text="@string/cheque_issued"
                android:textSize="13sp" />
        </RadioGroup>

        <EditText
            android:id="@+id/etChequeAmount"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:hint="@string/amount"
            android:importantForAutofill="no"
            android:inputType="phone"
            android:digits="0123456789.+-*/" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPickDueDate"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="10dp"
            android:text="@string/pick_due_date"
            xmlns:app="http://schemas.android.com/apk/res-auto"
            app:cornerRadius="8dp" />

        <EditText
            android:id="@+id/etChequeNumber"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:hint="@string/cheque_number_hint"
            android:importantForAutofill="no"
            android:inputType="text" />

        <EditText
            android:id="@+id/etBankName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:hint="@string/bank_name_hint"
            android:importantForAutofill="no"
            android:inputType="text" />

        <EditText
            android:id="@+id/etChequeNote"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:hint="@string/note_optional"
            android:importantForAutofill="no"
            android:inputType="text" />

    </LinearLayout>
</ScrollView>
