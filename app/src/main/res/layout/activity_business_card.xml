<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/page_bg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/biz_card"
            android:textColor="@color/ink"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="@string/biz_card_sub"
            android:textColor="@color/ink_soft"
            android:textSize="14sp" />

        <!-- Live preview of the card, redrawn on every keystroke -->
        <ImageView
            android:id="@+id/ivCardPreview"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:adjustViewBounds="true"
            android:contentDescription="@string/biz_card" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/biz_card_template"
            android:textColor="@color/ink"
            android:textSize="15sp"
            android:textStyle="bold" />

<!--
          Twelve designs, so the row scrolls rather than squeezing them onto
          one line. Filled in code, one chip per template, so adding a
          thirteenth is a line in CardTemplates and nothing here.
        -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:scrollbars="none">

            <LinearLayout
                android:id="@+id/templateRow"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal" />
        </HorizontalScrollView>

        <EditText
            android:id="@+id/etBizName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:hint="@string/biz_card_name_hint"
            android:inputType="textCapWords"
            android:minHeight="48dp"
            android:textSize="15sp" />

        <EditText
            android:id="@+id/etType"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:hint="@string/biz_card_type_hint"
            android:inputType="text"
            android:minHeight="48dp"
            android:textSize="15sp" />

        <EditText
            android:id="@+id/etOwner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:hint="@string/biz_card_owner_hint"
            android:inputType="textCapWords"
            android:minHeight="48dp"
            android:textSize="15sp" />

        <EditText
            android:id="@+id/etPhone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:hint="@string/biz_card_phone_hint"
            android:inputType="phone"
            android:minHeight="48dp"
            android:textSize="15sp" />

        <EditText
            android:id="@+id/etAddress"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:hint="@string/biz_card_address_hint"
            android:inputType="textPostalAddress"
            android:minHeight="48dp"
            android:textSize="15sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="@string/biz_card_note"
            android:textColor="@color/ink_soft"
            android:textSize="12sp" />

        <Button
            android:id="@+id/btnShareCard"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="14dp"
            android:layout_marginBottom="24dp"
            android:textAllCaps="false"
            android:text="@string/biz_card_share"
            android:textSize="16sp" />

    </LinearLayout>
</ScrollView>
