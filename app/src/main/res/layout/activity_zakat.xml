<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/page_bg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/section_tools"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/zakat_calculator"
                android:textColor="@color/white"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="@string/zakat_subtitle"
                android:textColor="@color/section_tools_soft"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- Disclaimer sits above everything, not buried at the bottom -->
        <TextView
            android:id="@+id/tvDisclaimer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#FFF6E0"
            android:padding="14dp"
            android:text="@string/zakat_disclaimer"
            android:textColor="#5C4A16"
            android:textSize="12sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Nisab -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/nisab_section"
                android:textColor="@color/navy_primary"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/nisab_help"
                android:textColor="@color/text_muted"
                android:textSize="12sp" />

            <!--
              Silver or gold standard, the owner's choice. Silver is the default
              because its nisab is lower, which brings more people into the
              obligation — the position generally taken as more careful toward
              the rights of the poor. A toggle, not a hidden setting, so the
              choice and its effect are visible.
            -->
            <com.google.android.material.button.MaterialButtonToggleGroup
                android:id="@+id/toggleNisab"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                app:singleSelection="true"
                app:selectionRequired="true">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSilver"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/nisab_silver"
                    android:textColor="@color/ink"
                    app:strokeColor="@color/section_tools" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnGold"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/nisab_gold"
                    android:textColor="@color/ink"
                    app:strokeColor="@color/section_tools" />
            </com.google.android.material.button.MaterialButtonToggleGroup>

            <!--
              The chosen standard, spelled out in grams (and tola). This is the
              detail the owner asked to see plainly — not just "silver" or "gold"
              but exactly how much metal the nisab is measured against.
            -->
            <TextView
                android:id="@+id/tvNisabStandardNote"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:textColor="@color/text_muted"
                android:textSize="12sp" />

            <EditText
                android:id="@+id/etSilverPrice"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:hint="@string/silver_price_hint"
                android:importantForAutofill="no"
                android:inputType="phone"
                android:digits="0123456789.+-*/%" />

            <TextView
                android:id="@+id/tvNisabValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="@color/navy_primary"
                android:textSize="13sp"
                android:textStyle="bold" />

            <!-- Cash & stock -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="@string/cash_stock_section"
                android:textColor="@color/navy_primary"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/cash_stock_help"
                android:textColor="@color/text_muted"
                android:textSize="12sp" />

            <EditText
                android:id="@+id/etCashStock"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:hint="@string/cash_stock_hint"
                android:importantForAutofill="no"
                android:inputType="phone"
                android:digits="0123456789.+-*/%" />

            <!-- From the ledger -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="@string/from_your_ledger"
                android:textColor="@color/navy_primary"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvCertain"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:textColor="@color/black"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tvQarzeHasna"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="@color/black"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tvDoubtful"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="@color/text_muted"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tvPayables"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="@color/red_gave"
                android:textSize="14sp" />

            <com.google.android.material.checkbox.MaterialCheckBox
                android:id="@+id/cbIncludeDoubtful"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/include_doubtful"
                android:textSize="13sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/include_doubtful_help"
                android:textColor="@color/text_muted"
                android:textSize="11sp" />

            <!-- Result -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:background="@color/section_tools"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/zakatable_wealth"
                    android:textColor="@color/gold_on_dark"
                    android:textSize="12sp" />

                <TextView
android:id="@+id/tvWealth"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/white"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="12dp"
                    android:layout_marginBottom="12dp"
                    android:background="@color/gold_accent" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/zakat_due_label"
                    android:textColor="@color/gold_on_dark"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/tvZakatDue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/gold_on_dark"
                    android:textSize="26sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvNisabStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:textColor="@color/section_tools_soft"
                    android:textSize="12sp" />
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="16dp"
                android:text="@string/zakat_footer_note"
                android:textColor="@color/text_muted"
                android:textSize="11sp" />

        </LinearLayout>
    </LinearLayout>
</ScrollView>
