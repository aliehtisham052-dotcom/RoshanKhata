<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingTop="8dp"
        android:paddingEnd="24dp"
        android:paddingBottom="8dp">

        <AutoCompleteTextView
            android:id="@+id/etBillSupplier"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:completionThreshold="1"
            android:hint="@string/bill_supplier_hint"
            android:importantForAutofill="no"
            android:inputType="text" />

        <EditText
            android:id="@+id/etBillNumber"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:hint="@string/bill_number_hint"
            android:importantForAutofill="no"
            android:inputType="text" />

        <EditText
            android:id="@+id/etBillTotal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:hint="@string/bill_total_hint"
            android:importantForAutofill="no"
            android:inputType="numberDecimal" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnBillDate"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="10dp"
            android:text="@string/pick_bill_date"
            app:cornerRadius="8dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnBillDue"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="8dp"
            android:text="@string/bill_due_date"
            app:cornerRadius="8dp" />

        <CheckBox
            android:id="@+id/cbPaidCash"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="@string/bill_paid_cash" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/bill_paid_cash_help"
            android:textColor="@color/text_muted"
            android:textSize="11sp" />

        <!-- What this bill will do to the ledger, stated before it is saved. -->
        <TextView
            android:id="@+id/tvBillLedgerEffect"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="#FFF6E0"
            android:padding="10dp"
            android:textColor="#5C4A16"
            android:textSize="12sp"
            android:visibility="gone" />

        <EditText
            android:id="@+id/etBillNote"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:hint="@string/note_optional"
            android:importantForAutofill="no"
            android:inputType="text" />

    </LinearLayout>
</ScrollView>
