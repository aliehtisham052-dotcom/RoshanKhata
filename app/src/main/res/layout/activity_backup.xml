<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/page_bg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/section_tools"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/backup_restore"
                android:textColor="@color/white"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="@string/backup_subtitle"
                android:textColor="@color/section_tools_soft"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- The plain truth about where the data lives, stated first -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#FFF6E0"
            android:padding="14dp"
            android:text="@string/backup_warning"
            android:textColor="#5C4A16"
            android:textSize="13sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!--
              The whole cloud-backup section is wrapped so it can be shown or
              hidden as one unit. It stays HIDDEN until Google has verified the
              app for the Drive scope — until then, a real user tapping Connect
              would meet an alarming "Google hasn't verified this app" screen,
              which for a ledger app is the opposite of reassuring. The code is
              finished and tested; it simply waits behind DriveFeature.ENABLED,
              which flips to true the day verification comes through. Nothing to
              rebuild but one flag.
            -->
            <LinearLayout
                android:id="@+id/driveSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

            <!--
              Cloud backup, given the top of the screen because it is the one
              that protects the owner without them having to remember. The file
              options below still matter — for a phone with no Google account, or
              for handing a copy to someone — but automatic is the safety net.
            -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/drive_section"
                android:textColor="@color/brand_green"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvDriveStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/drive_not_connected"
                android:textColor="@color/text_muted"
                android:textSize="13sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDriveConnect"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="12dp"
                android:text="@string/drive_connect"
                android:textColor="@color/white"
                android:textSize="15sp"
                app:backgroundTint="@color/brand_green"
                app:cornerRadius="10dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDriveBackupNow"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="10dp"
                android:text="@string/drive_backup_now"
                android:textColor="@color/white"
                android:textSize="15sp"
                android:visibility="gone"
                app:backgroundTint="@color/brand_green"
                app:cornerRadius="10dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDriveRestore"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="10dp"
                android:text="@string/drive_restore"
                android:textColor="@color/brand_green"
                android:textSize="15sp"
                android:visibility="gone"
                app:cornerRadius="10dp"
                app:strokeColor="@color/brand_green" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDriveSignOut"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/drive_sign_out"
                android:textColor="@color/text_muted"
                android:textSize="12sp"
                android:visibility="gone" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="4dp"
                android:background="@color/page_line" />

            </LinearLayout>
            <!-- end of the cloud-backup section (hidden until verified) -->

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/file_section"
                android:textColor="@color/ink"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/backup_explain"
                android:textColor="@color/text_muted"
                android:textSize="13sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnBackup"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="24dp"
                android:text="@string/backup_now"
                android:textSize="15sp"
                app:backgroundTint="@color/brand_green"
                app:cornerRadius="10dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnRestore"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="12dp"
                android:text="@string/restore_from_file"
                android:textColor="@color/brand_green"
                android:textSize="15sp"
                app:cornerRadius="10dp"
                app:strokeColor="@color/brand_green" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="24dp"
                android:background="#DDDDDD" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="@string/report_section_title"
                android:textColor="@color/ink"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/report_not_backup"
                android:textColor="@color/text_muted"
                android:textSize="12sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnReport"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="24dp"
                android:text="@string/make_report"
                android:textColor="@color/gold_accent"
                android:textSize="15sp"
                app:cornerRadius="10dp"
                app:strokeColor="@color/gold_accent" />

        </LinearLayout>
    </LinearLayout>
</ScrollView>
