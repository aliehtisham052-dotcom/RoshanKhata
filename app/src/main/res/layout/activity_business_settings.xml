<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/page_bg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/section_tools"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/business_settings"
                android:textColor="@color/white"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="@string/business_settings_subtitle"
                android:textColor="@color/section_tools_soft"
                android:textSize="12sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Business name -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/business_name"
                android:textColor="@color/navy_primary"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="@string/business_name_help"
                android:textColor="@color/text_muted"
                android:textSize="12sp" />

            <EditText
                android:id="@+id/etBusinessName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:hint="@string/business_name_hint"
                android:importantForAutofill="no"
                android:inputType="text" />

            <!-- Payment QR -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="26dp"
                android:text="@string/payment_qr"
                android:textColor="@color/navy_primary"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="@string/payment_qr_help"
                android:textColor="@color/text_muted"
                android:textSize="12sp" />

            <!-- The honest caveat, stated up front rather than discovered later -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="#FFF6E0"
                android:padding="12dp"
                android:text="@string/payment_qr_caveat"
                android:textColor="#5C4A16"
                android:textSize="12sp" />

            <ImageView
                android:id="@+id/ivQrPreview"
                android:layout_width="200dp"
                android:layout_height="200dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="14dp"
                android:background="@color/white"
                android:contentDescription="@string/payment_qr"
                android:padding="8dp"
                android:scaleType="fitCenter"
                android:visibility="gone" />

            <TextView
                android:id="@+id/tvNoQr"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:gravity="center"
                android:text="@string/no_qr_yet"
                android:textColor="@color/text_muted"
                android:textSize="13sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnPickQr"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="@string/choose_qr_image"
                    app:backgroundTint="@color/ink"
                    app:cornerRadius="10dp"
                    xmlns:app="http://schemas.android.com/apk/res-auto" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnRemoveQr"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:text="@string/remove_qr"
                    android:textColor="@color/red_gave"
                    android:visibility="gone"
                    app:cornerRadius="10dp"
                    app:strokeColor="@color/red_gave"
                    xmlns:app="http://schemas.android.com/apk/res-auto" />
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSaveProfile"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="16dp"
                android:text="@string/save"
                app:backgroundTint="@color/gold_accent"
                app:cornerRadius="10dp"
                xmlns:app="http://schemas.android.com/apk/res-auto" />

        </LinearLayout>
    </LinearLayout>
</ScrollView>
