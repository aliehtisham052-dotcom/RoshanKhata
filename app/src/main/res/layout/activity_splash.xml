<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/splashRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:clickable="true"
    android:focusable="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingStart="32dp"
        android:paddingEnd="32dp">

        <!--
          The logo is the whole point of the splash — it is the brand the owner
          is being asked to remember. It gets the centre of the screen and room
          to breathe.
        -->
        <!--
          A capped, aspect-correct logo that fits any screen. The parent is a
          LinearLayout, not a Constraint, so a width-percent won't apply here —
          adjustViewBounds + fitCenter keeps the aspect ratio and maxWidth caps
          it so it never reaches the edges on a narrow phone. The old fixed
          240dp square could overflow a small display.
        -->
        <ImageView
            android:layout_width="220dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:adjustViewBounds="true"
            android:contentDescription="@string/app_name"
            android:scaleType="fitCenter"
            android:src="@drawable/logo_full" />

    </LinearLayout>

    <!--
      "Powered by Innovation-313" sits at the foot, quiet but present. This is
      the brand line the owner asked to carry through the app — the maker's
      mark, not a heading. It belongs at the bottom, the way a colophon does.
    -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="48dp"
        android:gravity="center"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/powered_by"
            android:textColor="@color/brand_green"
            android:textSize="13sp"
            android:textStyle="bold" />

        <!--
          The fingerprint. Shown ONLY when app lock is on — the owner's point,
          and the right one: a lock symbol on an unlocked app is a promise the
          app is not keeping. When it appears, tapping it goes straight to the
          unlock prompt.
        -->
        <ImageView
            android:id="@+id/ivFingerprint"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginTop="14dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/unlock_to_open"
            android:padding="4dp"
            android:src="@drawable/ic_fingerprint"
            android:visibility="gone" />

        <!--
          The two prompts are mutually exclusive. Lock on -> "Touch to unlock"
          under the fingerprint. Lock off -> the plain "Tap to continue". Never
          both, because the app either needs unlocking or it does not.
        -->
        <TextView
            android:id="@+id/tvUnlockHint"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/unlock_to_open"
            android:textColor="@color/text_muted"
            android:textSize="11sp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/tvTapHint"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="@string/tap_to_continue"
            android:textColor="@color/text_muted"
            android:textSize="11sp" />
    </LinearLayout>

</FrameLayout>
