<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/splashRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:clickable="true"
    android:focusable="true">

    <!--
      Logo AND branding together, centred as one group.

      The tagline used to be pinned to the very bottom. That put it exactly where
      the biometric sheet rises from — so when the sensor appeared, it slid up
      over the tagline and shoved "Powered by Innovation-313" out of sight. The
      owner watched their own brand line get swallowed by the system prompt.

      Keeping the whole group centred, slightly above the middle, keeps the brand
      in the clear upper two-thirds where the sheet never reaches. Logo, then the
      mark beneath it, both always visible.
    -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingStart="32dp"
        android:paddingEnd="32dp">

        <ImageView
            android:layout_width="220dp"
            android:layout_height="wrap_content"
            android:adjustViewBounds="true"
            android:contentDescription="@string/app_name"
            android:scaleType="fitCenter"
            android:src="@drawable/logo_full" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:text="@string/powered_by"
            android:textColor="@color/brand_green"
            android:textSize="13sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvTapHint"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="@string/tap_to_continue"
            android:textColor="@color/text_muted"
            android:textSize="11sp" />

    </LinearLayout>

</FrameLayout>
