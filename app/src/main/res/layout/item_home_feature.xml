<?xml version="1.0" encoding="utf-8"?>
<!--
  One tile in the Home grid.

  The icon sits on a tinted disc rather than floating on white: twelve flat
  glyphs on twelve flat cards read as a list with decoration above each label,
  and the disc gives every tile a centre of gravity. Elevation is kept low and
  the corner radius generous, so the grid reads as a set of surfaces rather
  than a stack of raised boxes competing for depth.

  Inflated once per feature from code — an <include> would hand all twelve
  copies the same ids. Height and margin are set in createTile rather than
  here: inflating against a null parent discards every layout_* attribute in
  this file, so values written here would silently do nothing.
-->
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:foreground="?attr/selectableItemBackground"
    app:cardBackgroundColor="@color/white"
    app:cardCornerRadius="100dp"
    app:cardElevation="1dp">

    <LinearLayout
        android:id="@+id/featureRoot"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingTop="8dp"
        android:paddingBottom="8dp">

        <FrameLayout
            android:id="@+id/featureIconDisc"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:background="@drawable/bg_feature_icon">

            <ImageView
                android:id="@+id/ivFeatureIcon"
                android:layout_width="15dp"
                android:layout_height="15dp"
                android:layout_gravity="center"
                android:contentDescription="@null"
                tools:src="@drawable/ic_nav_khata" />
        </FrameLayout>

        <!--
          Two lines' worth of room whether the name needs it or not. Left to
          wrap_content, "Khata" made a short tile and "Business Settings" a
          tall one, and a grid of tiles at differing heights reads as a
          mistake however carefully each one is drawn.
        -->
        <TextView
            android:id="@+id/tvFeatureLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:lines="2"
            android:layout_marginTop="5dp"
            android:gravity="center"
            android:lineSpacingExtra="1dp"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:textColor="@color/ink"
            android:textSize="10sp"
            android:textStyle="bold"
            tools:text="Khata" />
    </LinearLayout>
</androidx.cardview.widget.CardView>
