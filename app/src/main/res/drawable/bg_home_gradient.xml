<?xml version="1.0" encoding="utf-8"?>
<!--
  The sheet the tiles sit on.

  A faint wash, greener where it meets the header and settling into the page
  colour further down — enough that the grid has a surface underneath it
  rather than floating on flat paper, and not so much that it competes with
  thirteen coloured cards.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <gradient
        android:angle="270"
        android:startColor="@color/page_grad_top"
        android:endColor="@color/page_grad_bottom"
        android:type="linear" />
</shape>
