<?xml version="1.0" encoding="utf-8"?>
<!--
  The disc the camera badge sits on. Dark and slightly ringed so the glyph
  reads whether the circle behind it holds a photograph or a monogram — a
  white camera on a pale avatar would disappear.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="oval">
    <solid android:color="#1B5E3A" />
    <stroke
        android:width="1dp"
        android:color="#FFFFFF" />
</shape>
