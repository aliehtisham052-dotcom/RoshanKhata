<?xml version="1.0" encoding="utf-8"?>
<!--
  The shape of a language key.

  Setting this as the background rather than asking the button to round itself:
  the LangKey style descends from Widget.AppCompat.Button, so the tag inflates
  as an AppCompat button and never becomes a MaterialButton — which meant the
  cornerRadius set in code was being applied to null and quietly doing nothing.
  A background drawable works whatever the button turns out to be.

  The radius is larger than the key is tall; Android clamps it to half the
  height, so the ends stay properly round if the height ever changes.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="#FFFFFF" />
    <corners android:radius="100dp" />
</shape>
