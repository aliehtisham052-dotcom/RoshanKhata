<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--
      Roshan Khata — "Ink & Paper".

      A shopkeeper reads this standing in the sun, on a cheap screen, often in
      a hurry. Dark text on a pale ground is what survives that. The navy header
      looked handsome indoors and washed out on a shop counter at two in the
      afternoon.

      The NAMES are deliberately unchanged. Twenty-odd layouts reference
      @color/navy_primary and @color/gold_accent; renaming them would mean
      touching every one of those files and inviting a mistake in each. Only the
      values move. The whole app re-themes at once, and nothing breaks.
    -->

    <!-- Surfaces: what was navy is now paper -->
    <color name="navy_deep">#EFEDE5</color>
    <color name="navy_primary">#FFFFFF</color>
    <color name="navy_surface">#FAF9F5</color>

    <!--
      Gold, darkened until it is legible AS TEXT.

      The old #D4A438 was a fill colour pressed into service as a label, and on
      white it barely registers. This is the same gold taken down to where it
      actually reads. Money is not the place to be subtle.
    -->
    <color name="gold_accent">#8A6A15</color>
    <color name="gold_bright">#8A6A15</color>

    <!-- The page beneath the cards -->
    <color name="page_bg">#F7F6F2</color>
    <color name="page_line">#E5E3DC</color>

    <color name="white">#FFFFFF</color>
    <color name="black">#1A1A18</color>
    <color name="text_muted">#6B6B66</color>

    <!--
      Ledger direction. Both darkened for the pale ground.

      These two carry the most important meaning in the app — who owes whom —
      and they now sit on white rather than navy, where the old shades would be
      too light to be sure of. Anyone who cannot easily tell red from green still
      has the label beneath the number.
    -->
    <color name="red_gave">#A32D2D</color>
    <color name="green_got">#0F6E56</color>

    <!-- Ink: text on paper -->
    <color name="ink">#1A1A18</color>
    <color name="ink_soft">#5F5E5A</color>

    <!--
      Section colours.

      Each screen gets its own header so the owner knows where they are at a
      glance — a shopkeeper mid-transaction should not have to read a title to
      tell the Cashbook from the cheque register.

      Every one of these was chosen to carry WHITE text at 7:1 or better. A
      header that looks handsome and cannot be read is worse than a plain one.
      The list beneath stays paper, so the numbers — which are the point — keep
      the contrast they need.
    -->
    <color name="section_khata">#1B5E3A</color>
    <color name="section_khata_soft">#B8D0C0</color>

    <color name="section_cashbook">#0E5236</color>
    <color name="section_cashbook_soft">#9FCBB0</color>

    <color name="section_cheques">#12564E</color>
    <color name="section_cheques_soft">#9FC9C0</color>

    <color name="section_plans">#3E5B2A</color>
    <color name="section_plans_soft">#C3D4A8</color>

    <color name="section_bills">#5C4A16</color>
    <color name="section_bills_soft">#E0D2A0</color>

    <color name="section_tools">#374A40</color>
    <color name="section_tools_soft">#A6BBAC</color>

    <!--
      Brand colours, taken from the logo.

      The deep green of the book and the gold of the R. These are the identity
      the owner chose; the section colours below are tuned to sit in the same
      family so the app reads as one thing rather than a row of unrelated
      headers.
    -->
    <color name="brand_green">#1B5E3A</color>
    <color name="brand_green_dark">#134228</color>
    <color name="brand_gold">#D4A02A</color>
    <color name="brand_gold_soft">#A9C4B0</color>

    <!--
      Customer-balance colours, deliberately separate from green_got/red_gave.

      The owner wants the shopkeeper's convention: money a customer OWES the shop
      (a receivable the owner must collect) shows RED with a minus, and money the
      SHOP owes shows GREEN with a plus. That is the opposite of the good=green
      instinct, so these live on their own names — flipping them here can never
      reach into the cashbook, cheques, expiry, or plans, which keep the plain
      green=good / red=bad meaning.
    -->
    <color name="bal_owed_to_me">#A32D2D</color>
    <color name="bal_i_owe">#0F6E56</color>
    <!-- Bright variants for use ON the dark green party header only -->
    <color name="bal_owed_to_me_on_dark">#FFA8A8</color>
    <color name="bal_i_owe_on_dark">#7FE3C4</color>
    <color name="section_insights">#1E5A4E</color>
    <color name="section_insights_soft">#A8CBC2</color>
</resources>
