<resources xmlns:tools="http://schemas.android.com/tools">
    <!--
      Ink & Paper.

      Every one of these used to name a dark colour. colorOnPrimary was white
      because colorPrimary was navy; with a paper primary, white-on-primary is
      white-on-white. The status bar was navy_deep, which is now a pale stone —
      a light status bar needs DARK icons, or the clock and battery vanish.
    -->
    <style name="Theme.RoshanKhata" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="android:forceDarkAllowed" tools:targetApi="q">false</item>
        <item name="colorPrimary">@color/ink</item>
        <item name="colorPrimaryVariant">@color/ink_soft</item>
        <item name="colorOnPrimary">@color/white</item>

        <item name="colorSecondary">@color/gold_accent</item>
        <item name="colorOnSecondary">@color/white</item>

        <item name="colorSurface">@color/white</item>
        <item name="colorOnSurface">@color/ink</item>

        <!--
          The status bar sits directly above the section header, which is dark.
          A white strip there would look like a mistake, and the clock would be
          fighting the header for attention. Match the header and let Android
          draw the clock and battery in light.
        -->
        <item name="android:statusBarColor" tools:targetApi="l">@color/section_khata</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">false</item>

        <item name="android:navigationBarColor" tools:targetApi="l">@color/white</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="o_mr1">true</item>

        <item name="android:windowBackground">@color/page_bg</item>
    </style>

    <!--
      The toolbar sits ON THE SECTION HEADER, which is dark. Its overflow icon
      must therefore be light, or the ⋮ is a menu button nobody can see — and an
      invisible menu button is exactly how the owner lost the settings the first
      time round.

      Named for where it sits rather than what colour it is, because the header
      colour has now changed twice and this style had to follow it both times.
    -->
    <style name="ToolbarInk" parent="ThemeOverlay.MaterialComponents.Toolbar.Primary">
        <item name="colorControlNormal">@color/white</item>
        <item name="android:textColorPrimary">@color/white</item>
        <item name="android:textColorSecondary">@color/white</item>
    </style>

    <!--
      The system splash — the frame Android 12+ shows on its own, before our
      SplashActivity even loads. Left unstyled, it falls back to the launcher
      icon on a default background: the little circle the owner saw flash up
      first, reading as a second, separate screen.

      Styled to match our splash exactly — the logo on white — so the two become
      one continuous screen. The handoff from system splash to our splash should
      be invisible.
    -->
    <style name="Theme.RoshanKhata.Splash" parent="Theme.SplashScreen">
        <!--
          Android 12+ forces a cold-start splash; it cannot be removed. So make
          it disappear into the app: the background matches the home screen and
          there is no icon, so the mandatory frame reads as nothing at all rather
          than a logo flashing by. postSplashScreenTheme hands straight to the
          app theme.
        -->
        <item name="windowSplashScreenBackground">@color/page_bg</item>
        <item name="android:windowBackground">@color/page_bg</item>
        <item name="android:windowDisablePreview">true</item>
        <item name="postSplashScreenTheme">@style/Theme.RoshanKhata</item>
    </style>


    <!-- Calculator keys for the GridLayout pad -->
    <style name="CalcCell" parent="Widget.AppCompat.Button">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">52dp</item>
        <item name="android:layout_margin">4dp</item>
        <item name="android:textSize">20sp</item>
        <item name="android:maxLines">2</item>
        <item name="android:includeFontPadding">false</item>
        <!--
          MaterialButton's own padding is 16dp a side, which took 32dp out of
          a key barely a third of the screen wide — enough that "Roman Urdu"
          had nowhere to go and was clipped to "Roman". The label needs the
          width more than the key needs the inset.
        -->
        <item name="android:paddingStart">4dp</item>
        <item name="android:paddingEnd">4dp</item>
        <item name="android:minWidth">0dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:insetLeft">0dp</item>
        <item name="android:insetRight">0dp</item>
        <item name="android:stateListAnimator">@null</item>
    </style>

    <style name="CalcCellTall" parent="CalcCell">
        <item name="android:layout_height">108dp</item>
    </style>


    <!-- Language picker buttons: white cards on the green welcome sheet -->
    <!--
      A MaterialButton parent, and every visual set through Material's own
      attributes. These tags become MaterialButtons under this theme whatever
      the style says, and a MaterialButton ignores android:background outright
      — it paints itself from backgroundTint, which is why dropping the tint
      turned the keys black: they fell back to colorPrimary, which is ink.
    -->
    <style name="LangKey" parent="Widget.MaterialComponents.Button.UnelevatedButton">
        <item name="android:layout_width">0dp</item>
        <!-- Room for two lines at full size, so a wrapped label is not squeezed. -->
        <item name="android:layout_height">64dp</item>
        <item name="android:layout_weight">1</item>
        <item name="android:layout_margin">5dp</item>
        <item name="android:textSize">15sp</item>
        <item name="android:textColor">#1A1A18</item>
        <item name="android:maxLines">2</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:includeFontPadding">false</item>
        <!--
          MaterialButton's own padding is 16dp a side, which took 32dp out of
          a key barely a third of the screen wide — enough that "Roman Urdu"
          had nowhere to go and was clipped to "Roman". The label needs the
          width more than the key needs the inset.
        -->
        <item name="android:paddingStart">4dp</item>
        <item name="android:paddingEnd">4dp</item>
        <item name="android:minWidth">0dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:insetLeft">0dp</item>
        <item name="android:insetRight">0dp</item>
        <item name="android:stateListAnimator">@null</item>
        <item name="backgroundTint">#FFFFFF</item>
        <!-- Half the height, so the ends stay properly round. -->
        <item name="cornerRadius">32dp</item>
    </style>

    <!-- Calculator keypad. Four keys to a row, each row an equal share. -->
    <style name="CalcRow">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:orientation">horizontal</item>
    </style>

    <style name="CalcKey" parent="Widget.MaterialComponents.Button.UnelevatedButton">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">78dp</item>
        <item name="android:layout_weight">1</item>
        <item name="android:layout_margin">5dp</item>
        <item name="android:textSize">26sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/ink</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="backgroundTint">@color/white</item>
        <item name="cornerRadius">16dp</item>
    </style>

    <!-- Operators, in the brand green so the eye finds them without reading. -->
    <style name="CalcKeyOp" parent="CalcKey">
        <item name="android:textColor">@color/white</item>
        <item name="backgroundTint">@color/brand_green</item>
    </style>

    <!-- Clear, backspace, percent: present but not competing for attention. -->
    <style name="CalcKeyMuted" parent="CalcKey">
        <item name="android:textColor">@color/ink_soft</item>
        <item name="backgroundTint">@color/page_line</item>
    </style>

    <!--
      The amount pad's keys. Same shape and colours as the Calculator screen's,
      a size down: this pad sits inside a dialog that also has to hold the
      amount, a note, item and quantity fields.
    -->
    <style name="CalcPadKey" parent="CalcKey">
        <item name="android:layout_height">52dp</item>
        <item name="android:layout_margin">3dp</item>
        <item name="android:textSize">18sp</item>
        <item name="cornerRadius">12dp</item>
    </style>

    <style name="CalcPadKeyOp" parent="CalcPadKey">
        <item name="android:textColor">@color/white</item>
        <item name="backgroundTint">@color/brand_green</item>
    </style>

    <style name="CalcPadKeyMuted" parent="CalcPadKey">
        <item name="android:textColor">@color/ink_soft</item>
        <item name="backgroundTint">@color/page_line</item>
    </style>

</resources>
